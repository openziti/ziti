connectors:
  default:
    sdk:
      identity_file: /home/{{ .Model.MustVariable "credentials.ssh.username" }}/fablab/cfg/{{ .Component.Id }}.json
      ha: {{ .Component.GetFlag "ha"}}
      max_control_underlays: 1

workloads:
  - name: throughput
    connector: default
    service_name: throughput-{{ if .Component.HasTag "east" }}east{{ else }}west{{ end }}

  - name: latency
    connector: default
    service_name: latency-{{ if .Component.HasTag "east" }}east{{ else }}west{{ end }}
