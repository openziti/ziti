# Example systemd drop-in override for ziti-router.service
#
# To apply: uncomment the directives you need, then run:
#
#   systemctl edit ziti-router.service --stdin < /opt/openziti/etc/router/override.conf.example
#
# Or edit interactively:
#
#   systemctl edit ziti-router.service
#
[Service]

# Allow binding low ports, e.g., 443/tcp. Required when ZITI_ROUTER_PORT <= 1024.
# AmbientCapabilities=CAP_NET_BIND_SERVICE

# Allow adding IP routes and iptables rules. Required when ZITI_ROUTER_MODE=tproxy.
# AmbientCapabilities=CAP_NET_ADMIN

# Use an alternate config file. You must clear ExecStartPre and ExecStart before redefining them.
# ExecStartPre=
# ExecStartPre=/opt/openziti/etc/router/entrypoint.bash check alt_config.yml
# ExecStart=
# ExecStart=/opt/openziti/bin/ziti router run alt_config.yml $ZITI_ARGS

# Pass additional arguments to the router, e.g., --log-formatter text
# This is set in service.env, but you can override it here.
# Environment=ZITI_ARGS=--log-formatter text
