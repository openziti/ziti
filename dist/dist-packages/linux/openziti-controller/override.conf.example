# Example systemd drop-in override for ziti-controller.service
#
# To apply: uncomment the directives you need, then run:
#
#   systemctl edit ziti-controller.service --stdin < /opt/openziti/etc/controller/override.conf.example
#
# Or edit interactively:
#
#   systemctl edit ziti-controller.service
#
[Service]

# Allow binding low ports, e.g., 443/tcp.
# NOTE: use TLS passthrough if fronting with a reverse proxy, i.e., "raw" TCP proxy.
# AmbientCapabilities=CAP_NET_BIND_SERVICE

# Use an alternate config file. You must clear ExecStartPre and ExecStart before redefining them.
# ExecStartPre=
# ExecStartPre=/opt/openziti/etc/controller/entrypoint.bash check alt_config.yml
# ExecStart=
# ExecStart=/opt/openziti/bin/ziti controller run alt_config.yml $ZITI_ARGS

# Pass additional arguments to the controller, e.g., --log-formatter text
# This is set in service.env, but you can override it here.
# Environment=ZITI_ARGS=--log-formatter text
